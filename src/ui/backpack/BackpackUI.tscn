text = "[center]💡 [color=#f5c651]Fusion Guide[/color]: Place compatible items adjacently on the grid; they will automatically combine after you pass a combat stage! (e.g. Rusty Sword + Poison Potion = Poison Sword, Rusty Sword + Vibrator = Vibrating Sword)
Drag items to the [color=#f5c651]Shop[/color] to sell them for 50% gold, or drag to the [color=#4ade80]Stash[/color] to unequip.
🖥️ [color=#4ade80]Screen Size[/color]: Press [color=#f5c651]F1[/color] (Small 800x600), [color=#f5c651]F2[/color] (Large 1600x1200), or [color=#f5c651]F3/F11[/color] (Fullscreen) to toggle window sizes.[/center]"
fit_content = true

